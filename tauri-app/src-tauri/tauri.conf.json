{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "峰运通数据管理系统",
  "version": "1.3.0",
  "identifier": "com.fengyuntong.data-management",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "峰运通数据管理系统",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/FYTCoreBridge"],
    "icon": ["../../assets/icon.ico"],
    "shortDescription": "峰运通内部数据处理工作台",
    "longDescription": "考勤、工时、销售、采购、送货及常用文件工具的一体化桌面工作台。",
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"]
      }
    }
  }
}
