{
  "name": "fyt-data-mgmt-tauri",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "build:sidecar": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-sidecar.ps1",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "qa:visual": "node scripts/visual-qa.mjs",
    "qa:functional": "node scripts/functional-qa.mjs",
    "tauri": "tauri",
    "tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-tauri.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.2",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.4",
    "playwright": "^1.61.1",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  }
}
